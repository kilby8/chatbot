FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-ollama.txt /app/requirements-ollama.txt
RUN pip install --no-cache-dir -r /app/requirements-ollama.txt

COPY ollama_api.py /app/ollama_api.py

RUN adduser --disabled-password --gecos "" appuser
USER appuser

EXPOSE 8000

CMD ["uvicorn", "ollama_api:app", "--host", "0.0.0.0", "--port", "8000"]
